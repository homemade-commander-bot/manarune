# Optional: Supabase cloud sync. The app works without these — it falls
# back to localStorage-only mode (no accounts required) if both are unset.
#
# To enable sync:
#   1. Create a free project at https://supabase.com
#   2. Project Settings → API → copy URL + anon/public key
#   3. Run the SQL in supabase/schema.sql against your project
#   4. Restart the dev server
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
